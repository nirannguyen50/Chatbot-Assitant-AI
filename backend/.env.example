# App
APP_NAME="Chatbot Platform"
DEBUG=false

# Database (SQLite mặc định, đổi sang PostgreSQL khi deploy)
DATABASE_URL=sqlite:///./chatbot.db
# DATABASE_URL=postgresql://user:password@localhost:5432/chatbot_db

# JWT - THAY ĐỔI KEY NÀY TRƯỚC KHI DEPLOY!
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# DeepSeek API (lấy tại: https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Embedding model (chạy local, free)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Storage
CHROMA_PERSIST_DIR=./chroma_db
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Email (SMTP) — dùng Gmail App Password
# Bật 2FA Gmail → myaccount.google.com/apppasswords → tạo App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=your@gmail.com

# URL gốc của server (dùng để tạo reset link trong email)
BASE_URL=http://localhost:8000
